local Runtime = {}

local cache = {}
local history = {}
local warmedUp = {}
local MAX_CACHE = 50

-- caches modules
local function loadModule(mod, idx)
	local c = cache[mod]
	if c then return c end

	-- sync for require
	task.synchronize()
	local ok, fn = pcall(require, mod)
	if ok then
		if #history >= MAX_CACHE then
			local old = table.remove(history, 1)
			if old then 
				cache[old] = nil 
				warmedUp[old] = nil
			end
		end
		cache[mod] = fn
		table.insert(history, mod)
	else
		warn("worker " .. idx .. " couldn't load module: " .. tostring(fn))
	end
	task.desynchronize()
	
	return cache[mod]
end

-- promotes sharedtables
local function promote(val)
	if typeof(val) == "SharedTable" or type(val) == "table" then
		local t = {}
		for k, v in val do t[k] = promote(v) end
		return t
	end
	return val
end

function Runtime.start(actor, Lib)
	local wid = actor:GetAttribute("PF_Index") or 0
	local ref = actor:WaitForChild("PF_ResultEvent", 5)
	if not ref then
		warn("worker " .. actor.Name .. " is missing the result event")
		return
	end
	
	local event = ref.Value
	local Serializer = Lib -- using the injected serializer

	-- standard dispatch
	actor:BindToMessageParallel("pf_task", function(mod, args)
		local t0 = os.clock()
		local fn = loadModule(mod, wid)
		if not fn then return end

		local raw = Serializer.decode(args)
		
		task.synchronize()
		actor:SetAttribute("PF_Busy", true)
		task.desynchronize()
		
		local ok, res = pcall(fn, raw)

		local elapsed = (os.clock() - t0) * 1000
		task.synchronize()
		actor:SetAttribute("PF_Busy", false)
		actor:SetAttribute("PF_LastRunMs", elapsed)
		event:Fire(wid, ok and Serializer.encode(res) or nil, ok)
	end)

	-- explicit warmup (eliminates load/sync cost from first real run)
	actor:BindToMessageParallel("pf_warmup", function(mod)
		if warmedUp[mod] then return end
		loadModule(mod, wid)
		warmedUp[mod] = true
	end)

	-- coalesced submit
	actor:BindToMessageParallel("pf_batch", function(mods, argsBuf)
		local t0 = os.clock()
		local args = Serializer.decode(argsBuf)
		if not args then return end

		local n = #args
		local out = table.create(n)
		local errs = nil

		for i = 1, n do
			local fn = loadModule(mods[i], wid)
			if fn then
				local ok, res = pcall(fn, args[i])
				if ok then
					out[i] = res
				else
					errs = errs or {}
					errs[#errs + 1] = { index = i, message = tostring(res) }
				end
			else
				errs = errs or {}
				errs[#errs + 1] = { index = i, message = "module load failed" }
			end
		end

		local elapsed = (os.clock() - t0) * 1000
		task.synchronize()
		actor:SetAttribute("PF_LastRunMs", elapsed)
		-- encode out and handle errors
		event:Fire(wid, Serializer.encode(out, 1, n), errs == nil, errs)
	end)

	task.synchronize()
	event:Fire(wid) -- handshake

	-- basic parallel map
	actor:BindToMessageParallel("pf_map", function(mod, buf)
		local t0 = os.clock()
		local fn = loadModule(mod, wid)
		if not fn then return end

		local data = Serializer.decode(buf)
		if not data then return end

		local n = #data
		local out = table.create(n)
		local errs = nil

		-- per-element isolation
		for i = 1, n do
			local ok, res = pcall(fn, data[i])
			if ok then
				out[i] = res
			else
				errs = errs or {}
				errs[#errs + 1] = { index = i, message = tostring(res) }
			end
		end

		local elapsed = (os.clock() - t0) * 1000
		task.synchronize()
		actor:SetAttribute("PF_LastRunMs", elapsed)
		-- fast encode when clean; hole-safe encode(out,1,n) only when gaps exist
		local payload = (errs == nil) and Serializer.encode(out) or Serializer.encode(out, 1, n)
		event:Fire(wid, payload, errs == nil, errs)
	end)

	-- sharedtable map
	actor:BindToMessageParallel("pf_map_shared", function(mod, start, finish, shared)
		local t0 = os.clock()
		local fn = loadModule(mod, wid)
		if not fn then return end

		local n = finish - start + 1
		local out = table.create(n)
		local errs = nil

		for i = 1, n do
			local val = shared[start + i - 1]
			local ok, res = pcall(fn, promote(val))
			if ok then
				out[i] = res
			else
				errs = errs or {}
				errs[#errs + 1] = { index = i, message = tostring(res) }
			end
		end

		local elapsed = (os.clock() - t0) * 1000
		task.synchronize()
		actor:SetAttribute("PF_LastRunMs", elapsed)
		local payload = (errs == nil) and Serializer.encode(out) or Serializer.encode(out, 1, n)
		event:Fire(wid, payload, errs == nil, errs)
	end)

	-- binary buffer map
	actor:BindToMessageParallel("pf_map_buffer", function(mod, buf, stride)
		local t0 = os.clock()
		local fn = loadModule(mod, wid)
		if not fn then return end

		local n = buffer.len(buf) / stride
		local out = table.create(n)
		local failed = false

		for i = 1, n do
			local ok, res = pcall(fn, buf, (i - 1) * stride)
			if ok then out[i] = res else failed = true break end
		end

		local elapsed = (os.clock() - t0) * 1000
		task.synchronize()
		actor:SetAttribute("PF_LastRunMs", elapsed)
		event:Fire(wid, not failed and Serializer.encode(out) or nil, not failed)
	end)

	-- map directly into a target table
	actor:BindToMessageParallel("pf_map_into", function(mod, start, finish, data, target)
		local t0 = os.clock()
		local fn = loadModule(mod, wid)
		if not fn then return end

		local n = finish - start + 1
		local failed = false

		local input = data
		if typeof(data) == "SharedTable" then
			input = table.create(n)
			for i = 1, n do input[i] = promote(data[start + i - 1]) end
		end

		for i = 1, n do
			local val = (typeof(data) == "SharedTable") and input[i] or data[start + i - 1]
			local ok, res = pcall(fn, val)
			if ok then target[start + i - 1] = res else failed = true break end
		end

		local elapsed = (os.clock() - t0) * 1000
		task.synchronize()
		actor:SetAttribute("PF_LastRunMs", elapsed)
		event:Fire(wid, nil, not failed)
	end)

	-- binary in, binary out
	actor:BindToMessageParallel("pf_map_buffer_out", function(mod, buf, stride, outStride)
		local t0 = os.clock()
		local fn = loadModule(mod, wid)
		if not fn then return end

		local n = buffer.len(buf) / stride
		local res = buffer.create(n * outStride)
		local ok = true

		for i = 1, n do
			local success = pcall(fn, buf, (i - 1) * stride, res, (i - 1) * outStride)
			if not success then ok = false break end
		end

		local elapsed = (os.clock() - t0) * 1000
		task.synchronize()
		actor:SetAttribute("PF_LastRunMs", elapsed)
		event:Fire(wid, ok and res or nil, ok)
	end)
end

return Runtime
